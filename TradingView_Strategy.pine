//@version=6
strategy("三策略量化系統 | Supertrend + VP + Bollinger",
         overlay            = true,
         initial_capital    = 100000,
         default_qty_type   = strategy.percent_of_equity,
         default_qty_value  = 10,
         commission_type    = strategy.commission.percent,
         commission_value   = 0.1,
         slippage           = 1,
         calc_on_every_tick = false,
         pyramiding         = 0)

// ══════════════════════════════════════════════════════════════════════════════
// 參數設定
// ══════════════════════════════════════════════════════════════════════════════
const string G1 = "策略1：Supertrend 趨勢動能"
const string G2 = "策略2：Volume Profile POC"
const string G3 = "策略3：Bollinger 均值回歸"
const string GC = "共用 / 風控"

st_period   = input.int  (10,    "ATR 期間",                  group=G1)
st_mult     = input.float(3.0,   "乘數",                       group=G1, step=0.1)

vp_lookback = input.int  (252,   "回顧 K 棒數（建議 ≤252）",   group=G2, minval=20, maxval=300)
vp_bins     = input.int  (80,    "分箱數",                     group=G2, minval=10, maxval=100)
vp_tol_pct  = input.float(1.5,   "POC 容差 %",                 group=G2, step=0.1)

bb_period   = input.int  (20,    "期間",                       group=G3)
bb_std_mult = input.float(2.0,   "標準差倍數",                 group=G3, step=0.1)
bb_bw_mult  = input.float(1.5,   "帶寬過濾乘數",               group=G3, step=0.1)
rsi_os      = input.int  (30,    "RSI 超賣門檻",               group=G3)
rsi_ob      = input.int  (70,    "RSI 超買門檻",               group=G3)

// EMA 環境濾網：固定使用 EMA20/50/100/200（對應 Python EMA_FAST_PERIODS + EMA_PERIOD）
// ema_min_score：多頭/空頭各需達到幾根 EMA 門檻才開放進場（預設 2/4）
ema_min_score = input.int  (2,    "EMA 環境最低分數（1–4）",   group=GC, minval=1, maxval=4)
rsi_len     = input.int  (14,    "RSI 期間",                   group=GC)
atr_len     = input.int  (14,    "ATR 止損期間",               group=GC)
atr_sl_mult = input.float(2.0,   "ATR 止損乘數",               group=GC, step=0.1)
rr_ratio    = input.float(3.0,   "風報比 1:N",                 group=GC, step=0.5)
use_short   = input.bool (true,  "允許做空",                   group=GC)

// ══════════════════════════════════════════════════════════════════════════════
// 基礎指標
// ══════════════════════════════════════════════════════════════════════════════
[st_line, st_dir]          = ta.supertrend(st_mult, st_period)
ema20                      = ta.ema(close, 20)
ema50                      = ta.ema(close, 50)
ema100                     = ta.ema(close, 100)
ema200                     = ta.ema(close, 200)
[bb_upper, bb_mid, bb_low] = ta.bb(close, bb_period, bb_std_mult)
bb_bw                      = (bb_upper - bb_low) / bb_mid * 100
bw_avg50                   = ta.sma(bb_bw, 50)
rsi                        = ta.rsi(close, rsi_len)
atr                        = ta.atr(atr_len)

// ══════════════════════════════════════════════════════════════════════════════
// 策略2：滾動 Volume Profile → POC
// 邏輯等同 Python compute_volume_profile()：將每根 K 棒的成交量
// 依 high/low 均分至對應的價格分箱，找出成交量最大的分箱中心
// ══════════════════════════════════════════════════════════════════════════════
f_rolling_poc(int lb, int bins) =>
    float plo   = ta.lowest (low,  lb)
    float phi   = ta.highest(high, lb)
    float bsize = (phi - plo) / bins
    float result = float(na)

    if bsize > 0
        float[] vp = array.new_float(bins, 0.0)

        for i = 0 to lb - 1
            float li = low  [i]
            float hi = high [i]
            float vi = volume[i]
            int sb = math.max(0, math.min(int(math.floor((li - plo) / bsize)), bins - 1))
            int eb = math.max(0, math.min(int(math.ceil ((hi - plo) / bsize)), bins - 1))
            int nb = eb - sb + 1
            if nb > 0
                float vpb = vi / nb
                for j = sb to eb
                    array.set(vp, j, array.get(vp, j) + vpb)

        int   poc_idx = array.indexof(vp, array.max(vp))
        result       := plo + (poc_idx + 0.5) * bsize

    result

poc = f_rolling_poc(vp_lookback, vp_bins)

// ══════════════════════════════════════════════════════════════════════════════
// 子策略訊號（+1 多 / -1 空 / 0 無）
// ══════════════════════════════════════════════════════════════════════════════
float vp_tol = vp_tol_pct / 100.0

// 策略1：Supertrend 只在方向反轉那根 K 棒才觸發訊號
int sig_tf = st_dir == 1 and st_dir[1] == -1 ? 1 :
             st_dir == -1 and st_dir[1] == 1  ? -1 : 0

// 策略2：前一根 Close 在 POC 上/下 → 今日觸碰 POC（支撐/壓力）
bool near_poc = not na(poc) and close >= poc * (1 - vp_tol) and close <= poc * (1 + vp_tol)
bool prev_abv = not na(poc) and close[1] > poc
bool prev_blw = not na(poc) and close[1] < poc
int sig_vp = 0
if near_poc and prev_abv and rsi < 60
    sig_vp := 1
else if near_poc and prev_blw and rsi > 40
    sig_vp := -1

// 策略3：Bollinger 均值回歸 + ATR 帶寬過濾
bool normal_vol     = bb_bw < bw_avg50 * bb_bw_mult
bool has_bw_history = bar_index >= 50   // 前 BB_PERIOD+50 棒暖身完成
int sig_bb = 0
if close <= bb_low and rsi < rsi_os and normal_vol and has_bw_history
    sig_bb := 1
else if close >= bb_upper and rsi > rsi_ob and normal_vol and has_bw_history
    sig_bb := -1

// ══════════════════════════════════════════════════════════════════════════════
// EMA 比例分數環境濾網（對應 Python _ema_scores + combine_signals）
// 多頭/空頭分數：收盤高/低於幾根 EMA（20/50/100/200），各 0–4 分
// ══════════════════════════════════════════════════════════════════════════════
int bull_score = (close > ema20 ? 1 : 0) + (close > ema50 ? 1 : 0) + (close > ema100 ? 1 : 0) + (close > ema200 ? 1 : 0)
int bear_score = (close < ema20 ? 1 : 0) + (close < ema50 ? 1 : 0) + (close < ema100 ? 1 : 0) + (close < ema200 ? 1 : 0)

bool bull_env  = bull_score >= ema_min_score
bool bear_env  = bear_score >= ema_min_score
bool any_long  = sig_tf == 1  or sig_vp == 1  or sig_bb == 1
bool any_short = sig_tf == -1 or sig_vp == -1 or sig_bb == -1

// 合併訊號（對應 Python combine_signals Bug 2 修正）
// 優先設 LONG，SHORT 再覆蓋；衝突時以 EMA 分數決勝，完全相同則 FLAT
int sig = 0
if bull_env and any_long
    sig := 1
if bear_env and any_short and use_short
    sig := -1

// 衝突解消：兩方向 EMA 門檻同時達標且子策略訊號方向相反
bool conflict = bull_env and any_long and bear_env and any_short and use_short
if conflict
    if bull_score > bear_score
        sig := 1
    else if bull_score == bear_score
        sig := 0
    // bear_score > bull_score → sig 維持 -1

// 共識分數（1–3 分，越高優先度越高）
int score_l = (sig_tf == 1  ? 1 : 0) + (sig_vp == 1  ? 1 : 0) + (sig_bb == 1  ? 1 : 0)
int score_s = (sig_tf == -1 ? 1 : 0) + (sig_vp == -1 ? 1 : 0) + (sig_bb == -1 ? 1 : 0)
int score = sig == 1 ? score_l : sig == -1 ? score_s : 0

// ══════════════════════════════════════════════════════════════════════════════
// 動態 ATR 移動停利管理
// 等同 Python backtester：多頭追蹤最高價，空頭追蹤最低價
// ══════════════════════════════════════════════════════════════════════════════
var float trail_peak    = na
var float entry_sl_dist = na

bool is_long  = strategy.position_size > 0
bool is_short = strategy.position_size < 0

if strategy.position_size != 0 and strategy.position_size[1] == 0
    trail_peak    := strategy.position_avg_price
    entry_sl_dist := atr[1] * atr_sl_mult

if is_long
    trail_peak := math.max(trail_peak, high)

if is_short
    trail_peak := math.min(trail_peak, low)

// ══════════════════════════════════════════════════════════════════════════════
// 進出場指令
// ══════════════════════════════════════════════════════════════════════════════
if sig == 1 and not is_long and not is_short
    strategy.entry("Long",  strategy.long,  comment="L" + str.tostring(score) + "★")

if sig == -1 and not is_long and not is_short
    strategy.entry("Short", strategy.short, comment="S" + str.tostring(score) + "★")

if is_long and not na(entry_sl_dist)
    float dyn_sl = trail_peak - entry_sl_dist
    float tp     = strategy.position_avg_price + entry_sl_dist * rr_ratio
    if sig == -1
        strategy.close("Long", comment="Flip↓")
    else
        strategy.exit("LX", "Long", stop=dyn_sl, limit=tp, comment="Exit")

if is_short and not na(entry_sl_dist)
    float dyn_sl = trail_peak + entry_sl_dist
    float tp     = strategy.position_avg_price - entry_sl_dist * rr_ratio
    if sig == 1
        strategy.close("Short", comment="Flip↑")
    else
        strategy.exit("SX", "Short", stop=dyn_sl, limit=tp, comment="Exit")

// ══════════════════════════════════════════════════════════════════════════════
// 視覺化
// ══════════════════════════════════════════════════════════════════════════════
plot(ema20,    "EMA20",    color.new(color.yellow, 65), 1)
plot(ema50,    "EMA50",    color.new(color.orange, 50), 1)
plot(ema100,   "EMA100",   color.new(color.orange, 20), 1)
plot(ema200,   "EMA200",   color.new(color.orange,  0), 2)

color st_color = st_dir == 1 ? color.new(color.teal, 20) : color.new(color.red, 20)
plot(st_line,  "Supertrend", st_color, 1)

plot(poc,      "POC",      color.new(color.purple, 30), 1, plot.style_circles)
plot(bb_upper, "BB Upper", color.new(color.blue, 65))
plot(bb_low,   "BB Lower", color.new(color.blue, 65))

plotshape(sig ==  1 and strategy.position_size[1] == 0, "做多訊號",
          shape.triangleup,   location.belowbar, color.lime, size=size.small)
plotshape(sig == -1 and strategy.position_size[1] == 0, "做空訊號",
          shape.triangledown, location.abovebar, color.red,  size=size.small)

if score >= 2 and sig != 0 and sig != sig[1]
    label.new(bar_index,
              sig == 1 ? low * 0.998 : high * 1.002,
              str.tostring(score) + "★",
              color     = sig == 1 ? color.new(color.lime, 20) : color.new(color.red, 20),
              textcolor = color.white,
              style     = sig == 1 ? label.style_label_up : label.style_label_down,
              size      = size.tiny)

// 環境背景：依 EMA 分數強弱顯示深淺（≥3 較深，=2 較淡）
color env_bg = color(na)
if bull_score >= 3
    env_bg := color.new(color.green, 93)
else if bull_score == 2
    env_bg := color.new(color.green, 96)
else if bear_score >= 3
    env_bg := color.new(color.red, 93)
else if bear_score == 2
    env_bg := color.new(color.red, 96)
bgcolor(env_bg, title="環境背景")

// ── 右上角子策略狀態表（新增 EMA 分數列）
var table tbl = table.new(position.top_right, 3, 5,
                          bgcolor=color.new(color.black, 55), border_width=1)
if barstate.islast
    table.cell(tbl, 0, 0, "策略",        text_color=color.silver, text_size=size.tiny)
    table.cell(tbl, 1, 0, "多  ▲",      text_color=color.lime,   text_size=size.tiny)
    table.cell(tbl, 2, 0, "空  ▼",      text_color=color.red,    text_size=size.tiny)
    table.cell(tbl, 0, 1, "Supertrend",  text_color=color.white,  text_size=size.tiny)
    table.cell(tbl, 1, 1, sig_tf == 1  ? "●" : "", text_color=color.lime, text_size=size.small)
    table.cell(tbl, 2, 1, sig_tf == -1 ? "●" : "", text_color=color.red,  text_size=size.small)
    table.cell(tbl, 0, 2, "VP POC",     text_color=color.white,  text_size=size.tiny)
    table.cell(tbl, 1, 2, sig_vp == 1  ? "●" : "", text_color=color.lime, text_size=size.small)
    table.cell(tbl, 2, 2, sig_vp == -1 ? "●" : "", text_color=color.red,  text_size=size.small)
    table.cell(tbl, 0, 3, "Bollinger",  text_color=color.white,  text_size=size.tiny)
    table.cell(tbl, 1, 3, sig_bb == 1  ? "●" : "", text_color=color.lime, text_size=size.small)
    table.cell(tbl, 2, 3, sig_bb == -1 ? "●" : "", text_color=color.red,  text_size=size.small)
    table.cell(tbl, 0, 4, "EMA 分數",   text_color=color.silver, text_size=size.tiny)
    table.cell(tbl, 1, 4, str.tostring(bull_score) + "/4", text_color=color.lime, text_size=size.tiny)
    table.cell(tbl, 2, 4, str.tostring(bear_score) + "/4", text_color=color.red,  text_size=size.tiny)
